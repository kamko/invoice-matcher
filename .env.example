# Google OAuth / OIDC (required for login and Drive integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/gdrive/callback

# Session / application security
SECRET_KEY=change-me
SESSION_COOKIE_SECURE=false
TRUSTED_HOSTS=["localhost","127.0.0.1"]
ALLOWED_EMAIL_ADDRESSES=
ALLOWED_EMAIL_DOMAINS=

# Optional dedicated key for encrypting stored provider credentials
ENCRYPTION_KEY=

# Debug mode
DEBUG=false
